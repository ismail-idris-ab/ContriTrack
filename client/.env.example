# Copy this to .env and fill in your values. Never commit .env.

# Backend API base URL (no trailing slash)
# Dev: http://localhost:5000
# Prod: https://your-api.onrender.com
VITE_API_URL=http://localhost:5000

# Google OAuth 2.0 Client ID
# Create at https://console.cloud.google.com — Credentials > OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Paystack public key — used for Paystack Inline checkout
# Get from https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
