# Copy this file to .env and fill in real values. Never commit .env.

# Node environment — set to "production" on Render
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?appName=<AppName>

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_use_64_random_hex_chars

# Server port
PORT=5000

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (e.g. https://rotara.vercel.app)
CLIENT_URL=http://localhost:3000

# Your deployed backend URL (e.g. https://rotara-api.onrender.com)
# Used to build email verification links that point directly to the backend
SERVER_URL=http://localhost:5000

# ─── Cloudinary (file uploads / proof images) ─────────────────────────────────
# Sign up free at https://cloudinary.com — find these in Dashboard > Settings > API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail example: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=your_app_password
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="ROTARA" <you@gmail.com>

# ─── Paystack (subscriptions / payments) ──────────────────────────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key

# Create plans at https://dashboard.paystack.com/#/plans — paste the plan codes here
PAYSTACK_PLAN_PRO_MONTHLY=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_PRO_ANNUAL=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_COORDINATOR_MONTHLY=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_COORDINATOR_ANNUAL=PLN_xxxxxxxxxxxxxxx

# ─── Termii (WhatsApp / SMS notifications) ────────────────────────────────────
# Sign up at https://termii.com — find your API key in the dashboard
# Leave blank to disable WhatsApp notification delivery
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=your_sender_id
