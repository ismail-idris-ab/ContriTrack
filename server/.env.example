# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?appName=<AppName>

# JWT signing secret — generate with: node -e "require('crypto').randomBytes(48).toString('hex')|console.log"
JWT_SECRET=change_me_use_64_random_hex_chars

# Server port
PORT=5000

# ─── Email (optional) ────────────────────────────────────────────────
# If not set, email notifications are silently skipped.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="ContriTrack <noreply@example.com>"
